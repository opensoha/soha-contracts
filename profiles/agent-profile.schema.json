{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/profiles/agent-profile.schema.json",
  "title": "OpenSoha Agent Profile",
  "description": "Public agent runtime profile manifest used to bind skills, MCP presets, capabilities, scopes, tools, budgets, and guardrails.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "description",
    "mode",
    "providerKind",
    "skillRefs",
    "mcpPresetRefs",
    "capabilityRefs",
    "platformCapabilityRefs",
    "requiredScopes",
    "enabledToolRefs",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "const": "opensoha.dev/agent-profile/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+][A-Za-z0-9.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "root_cause",
        "inspection",
        "performance",
        "trace",
        "delivery_failure",
        "platform_resource_diagnosis",
        "oncall_brief"
      ]
    },
    "providerKind": {
      "type": "string",
      "minLength": 1
    },
    "skillRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "mcpPresetRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "capabilityRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "platformCapabilityRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enabledToolRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "disabledToolRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "budgets": {
      "type": "object",
      "properties": {
        "defaultTimeRangeMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "maxLogLines": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
