{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/memory/memory-policy.schema.json",
  "title": "Long-Term Memory Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "ownerTypes", "defaultTtlSeconds", "maximumTtlSeconds", "minimumConfidence", "explicitWriteOnly", "enabled"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/memory-policy/v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "ownerTypes": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "enum": ["user", "session", "agent"] } },
    "defaultTtlSeconds": { "type": "integer", "minimum": 1, "maximum": 31536000 },
    "maximumTtlSeconds": { "type": "integer", "minimum": 1, "maximum": 31536000 },
    "minimumConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "explicitWriteOnly": { "type": "boolean" },
    "enabled": { "type": "boolean" }
  }
}
