{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/memory/memory-record.schema.json",
  "title": "Explicit Long-Term Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "ownerType", "ownerId", "scopeHash", "fact", "sourceType", "confidence", "validFrom", "policyVersion", "status", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/memory-record/v1" },
    "id": { "type": "string", "minLength": 1 },
    "ownerType": { "enum": ["user", "session", "agent"] },
    "ownerId": { "type": "string", "minLength": 1 },
    "scopeHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "fact": { "type": "string", "minLength": 1, "maxLength": 8000 },
    "sourceType": { "enum": ["explicit_user", "curated_extractor"] },
    "sourceRefs": { "type": "array", "maxItems": 32, "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "policyVersion": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "expired", "deleted"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "deletedAt": { "type": "string", "format": "date-time" }
  }
}
