{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/presets/mcp-preset.schema.json",
  "title": "OpenSoha MCP Preset",
  "description": "Public MCP preset manifest used to package Gateway tools, resources, prompts, scopes, capabilities, risk, and guardrails.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "description",
    "riskLevel",
    "skillRefs",
    "platformCapabilityRefs",
    "requiredScopes",
    "tools",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "const": "opensoha.dev/mcp-preset/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+][A-Za-z0-9.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": ["read", "analyze", "mutate", "execute", "high"]
    },
    "skillRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "platformCapabilityRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/MCPPresetCapability"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MCPPresetCapability"
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MCPPresetCapability"
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "RiskLevel": {
      "type": "string",
      "enum": ["read", "analyze", "mutate", "execute", "high"]
    },
    "MCPPresetCapability": {
      "type": "object",
      "required": ["name", "description", "requiredScopes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "riskLevel": {
          "$ref": "#/$defs/RiskLevel"
        },
        "requiredScopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
