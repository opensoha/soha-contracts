{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/plugins/plugin-manifest.schema.json",
  "title": "OpenSoha Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "publisher", "type"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*\\.[a-z0-9][a-z0-9._-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "skill",
        "skill-pack",
        "mcp-preset",
        "connector",
        "ai-provider-adapter",
        "agent-profile",
        "gateway-policy-pack"
      ]
    },
    "description": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "compatibility": {
      "type": "object",
      "properties": {
        "soha": { "type": "string" },
        "contracts": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "assets": {
      "type": "object",
      "properties": {
        "skills": { "type": "array", "items": { "type": "string" } },
        "mcpPresets": { "type": "array", "items": { "type": "string" } },
        "connectors": { "type": "array", "items": { "type": "string" } },
        "aiProviderAdapters": { "type": "array", "items": { "type": "string" } },
        "agentProfiles": { "type": "array", "items": { "type": "string" } },
        "gatewayPolicyPacks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "tools": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "array", "items": { "type": "string" } },
        "prompts": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } },
        "domain": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean" },
              "secretRef": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "properties": {
        "checksum": { "type": "string" },
        "signature": { "type": "string" },
        "verified": { "type": "boolean" },
        "status": { "type": "string" }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
