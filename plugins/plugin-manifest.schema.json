{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/plugins/plugin-manifest.schema.json",
  "title": "OpenSoha Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "publisher", "type"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*\\.[a-z0-9][a-z0-9._-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "skill",
        "skill-pack",
        "mcp-preset",
        "connector",
        "ai-provider-adapter",
        "agent-profile",
        "gateway-policy-pack",
        "diagnostic",
        "resource-extension",
        "metric-extension",
        "notification-channel",
        "identity-template",
        "ui-extension"
      ]
    },
    "description": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "compatibility": {
      "type": "object",
      "properties": {
        "soha": { "type": "string" },
        "contracts": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "assets": {
      "type": "object",
      "properties": {
        "skills": { "type": "array", "items": { "type": "string" } },
        "mcpPresets": { "type": "array", "items": { "type": "string" } },
        "connectors": { "type": "array", "items": { "type": "string" } },
        "aiProviderAdapters": { "type": "array", "items": { "type": "string" } },
        "agentProfiles": { "type": "array", "items": { "type": "string" } },
        "gatewayPolicyPacks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "tools": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "array", "items": { "type": "string" } },
        "prompts": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } },
        "domain": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean" },
              "secretRef": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "properties": {
        "checksum": { "type": "string" },
        "signature": { "type": "string" },
        "verified": { "type": "boolean" },
        "status": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["manifest-only", "external-http", "managed-container"]
        },
        "endpoint": { "type": "string" },
        "healthPath": { "type": "string" },
        "manifestPath": { "type": "string" },
        "actionPath": { "type": "string" },
        "webhookPath": { "type": "string" },
        "metricsPath": { "type": "string" },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "configSchema": { "$ref": "#/$defs/jsonSchema" },
    "extensionPoints": { "$ref": "#/$defs/extensionPoints" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "extensionPoints": {
                "properties": {
                  "compute": {
                    "properties": {
                      "virtualizationProviders": {
                        "contains": {
                          "properties": { "activationLevel": { "enum": ["read", "write"] } },
                          "required": ["activationLevel"]
                        }
                      }
                    },
                    "required": ["virtualizationProviders"]
                  }
                },
                "required": ["compute"]
              }
            },
            "required": ["extensionPoints"]
          },
          {
            "properties": {
              "extensionPoints": {
                "properties": {
                  "compute": {
                    "properties": {
                      "containerRuntimeProviders": {
                        "contains": {
                          "properties": { "activationLevel": { "enum": ["read", "write"] } },
                          "required": ["activationLevel"]
                        }
                      }
                    },
                    "required": ["containerRuntimeProviders"]
                  }
                },
                "required": ["compute"]
              }
            },
            "required": ["extensionPoints"]
          }
        ]
      },
      "then": {
        "required": ["runtime"],
        "properties": {
          "runtime": {
            "properties": {
              "mode": { "enum": ["external-http", "managed-container"] }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "jsonSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "contribution": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "actionRef": { "type": "string" },
        "resourceKinds": { "type": "array", "items": { "type": "string" } },
        "permissionKeys": { "type": "array", "items": { "type": "string" } },
        "match": { "$ref": "#/$defs/jsonSchema" },
        "configSchema": { "$ref": "#/$defs/jsonSchema" },
        "uiSchema": { "$ref": "#/$defs/jsonSchema" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "contributionList": {
      "type": "array",
      "items": { "$ref": "#/$defs/contribution" }
    },
    "computeProviderBase": {
      "type": "object",
      "required": ["providerKey", "displayName", "activationLevel", "resourceKinds", "capabilities"],
      "properties": {
        "providerKey": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "activationLevel": {
          "type": "string",
          "enum": ["descriptor", "read", "write"]
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "configSchemaRef": { "type": "string", "minLength": 1 },
        "actionRefs": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "activationLevel": { "const": "write" } },
            "required": ["activationLevel"]
          },
          "then": {
            "required": ["actionRefs"],
            "properties": { "actionRefs": { "minProperties": 1 } }
          }
        }
      ]
    },
    "virtualizationProviderContribution": {
      "allOf": [
        { "$ref": "#/$defs/computeProviderBase" },
        {
          "type": "object",
          "properties": {
            "resourceKinds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["connection", "cluster", "vm", "image", "flavor"]
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "containerRuntimeProviderContribution": {
      "allOf": [
        { "$ref": "#/$defs/computeProviderBase" },
        {
          "type": "object",
          "properties": {
            "resourceKinds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["runtime_host", "container", "project", "service", "port", "template"]
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "extensionPoints": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "sources": { "$ref": "#/$defs/contributionList" },
            "profileMappers": { "$ref": "#/$defs/contributionList" },
            "directorySync": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "identity": {
          "type": "object",
          "properties": {
            "applicationTemplates": { "$ref": "#/$defs/contributionList" },
            "providerTemplates": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "ui": {
          "type": "object",
          "properties": {
            "menus": { "$ref": "#/$defs/contributionList" },
            "settingsForms": { "$ref": "#/$defs/contributionList" },
            "statusCards": { "$ref": "#/$defs/contributionList" },
            "detailPanels": { "$ref": "#/$defs/contributionList" },
            "actionButtons": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "ai": {
          "type": "object",
          "properties": {
            "agentProviders": { "$ref": "#/$defs/contributionList" },
            "modelProviders": { "$ref": "#/$defs/contributionList" },
            "toolProviders": { "$ref": "#/$defs/contributionList" },
            "skillPacks": { "$ref": "#/$defs/contributionList" },
            "mcpPresets": { "$ref": "#/$defs/contributionList" },
            "analysisWorkflows": { "$ref": "#/$defs/contributionList" },
            "artifactRenderers": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "resource": {
          "type": "object",
          "properties": {
            "tags": { "$ref": "#/$defs/contributionList" },
            "actions": { "$ref": "#/$defs/contributionList" },
            "tabs": { "$ref": "#/$defs/contributionList" },
            "diagnostics": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "object",
          "properties": {
            "providers": { "$ref": "#/$defs/contributionList" },
            "definitions": { "$ref": "#/$defs/contributionList" },
            "panels": { "$ref": "#/$defs/contributionList" },
            "enrichers": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "alerts": {
          "type": "object",
          "properties": {
            "notificationChannels": { "$ref": "#/$defs/contributionList" },
            "receivers": { "$ref": "#/$defs/contributionList" },
            "enrichers": { "$ref": "#/$defs/contributionList" },
            "escalationProviders": { "$ref": "#/$defs/contributionList" },
            "silenceAdapters": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "delivery": {
          "type": "object",
          "properties": {
            "buildProviders": { "$ref": "#/$defs/contributionList" },
            "scanProviders": { "$ref": "#/$defs/contributionList" },
            "releaseGates": { "$ref": "#/$defs/contributionList" },
            "deployStrategies": { "$ref": "#/$defs/contributionList" },
            "artifactStores": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "gateway": {
          "type": "object",
          "properties": {
            "tools": { "$ref": "#/$defs/contributionList" },
            "resources": { "$ref": "#/$defs/contributionList" },
            "prompts": { "$ref": "#/$defs/contributionList" },
            "policies": { "$ref": "#/$defs/contributionList" }
          },
          "additionalProperties": false
        },
        "compute": {
          "type": "object",
          "properties": {
            "virtualizationProviders": {
              "type": "array",
              "items": { "$ref": "#/$defs/virtualizationProviderContribution" }
            },
            "containerRuntimeProviders": {
              "type": "array",
              "items": { "$ref": "#/$defs/containerRuntimeProviderContribution" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
