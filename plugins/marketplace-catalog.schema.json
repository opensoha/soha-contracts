{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/plugins/marketplace-catalog.schema.json",
  "title": "OpenSoha Marketplace Catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "sourceId", "plugins"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "marketplace.opensoha.io/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string" },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/plugin" }
    },
    "advisories": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": ["id", "name", "version", "publisher", "type", "source", "manifest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "summary": { "type": "string" },
        "source": { "type": "string" },
        "sourceId": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "riskLevel": { "type": "string" },
        "latestVersion": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean" },
        "publisherInfo": { "$ref": "#/$defs/publisher" },
        "compatibility": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "versions": {
          "type": "array",
          "items": { "$ref": "#/$defs/version" }
        },
        "advisories": {
          "type": "array",
          "items": { "$ref": "#/$defs/advisory" }
        },
        "deprecated": { "type": "boolean" },
        "suspended": { "type": "boolean" },
        "manifest": {
          "type": "object",
          "additionalProperties": true
        },
        "installed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "publisher": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "verified": { "type": "boolean" },
        "verificationLevel": {
          "type": "string",
          "enum": ["official", "verified", "community", "private"]
        },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "object",
      "required": ["version", "manifestUrl"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "manifestUrl": { "type": "string", "minLength": 1 },
        "packageUrl": { "type": "string" },
        "checksum": { "type": "string" },
        "signature": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "deprecated": { "type": "boolean" },
        "suspended": { "type": "boolean" },
        "minSohaVersion": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "advisory": {
      "type": "object",
      "required": ["id", "severity", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "affectedVersions": { "type": "array", "items": { "type": "string" } },
        "withdrawn": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
