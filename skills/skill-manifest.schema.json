{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/skills/skill-manifest.schema.json",
  "title": "Soha Skill Manifest",
  "description": "Structured front matter extracted from official Soha skill markdown files.",
  "type": "object",
  "required": ["id", "name", "category"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "capabilityRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "permissionKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "providerSkillRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["providerKind", "ref"],
        "properties": {
          "providerKind": { "type": "string" },
          "ref": { "type": "string" },
          "arguments": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

