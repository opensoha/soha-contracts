{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/knowledge/knowledge-search.schema.json",
  "title": "Knowledge Search Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["knowledgeBaseIds", "query"],
  "properties": {
    "knowledgeBaseIds": { "type": "array", "minItems": 1, "maxItems": 50, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "query": { "type": "string", "minLength": 1, "maxLength": 16000 },
    "topK": { "type": "integer", "minimum": 1, "maximum": 50 },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "documentIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
