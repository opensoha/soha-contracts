{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/evaluation/sample-attempt.schema.json",
  "title": "Evaluation Sample Attempt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "sampleId", "attempt", "candidateRefs", "status", "latencyMillis", "completedAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/evaluation-sample-attempt/v1" },
    "runId": { "type": "string", "minLength": 1 },
    "sampleId": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1, "maximum": 10 },
    "candidateRefs": { "type": "object", "minProperties": 1, "maxProperties": 32, "additionalProperties": { "type": "string" } },
    "traceRef": { "type": "string" },
    "scores": { "type": "object", "maxProperties": 128, "additionalProperties": { "type": "number" } },
    "usage": { "type": "object", "maxProperties": 32, "additionalProperties": { "type": "number", "minimum": 0 } },
    "latencyMillis": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["completed", "failed", "cancelled"] },
    "errorCode": { "type": "string" },
    "completedAt": { "type": "string", "format": "date-time" }
  }
}
