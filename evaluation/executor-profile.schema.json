{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/evaluation/executor-profile.schema.json",
  "title": "Evaluation Executor Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "environmentPolicy", "isolationMode", "timeoutSeconds", "enabled"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/evaluation-executor-profile/v1" },
    "id": { "type": "string", "minLength": 1 },
    "environmentPolicy": { "type": "string", "minLength": 1 },
    "toolSnapshotRef": { "type": "string" },
    "isolationMode": { "enum": ["read-only", "disposable-write"] },
    "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 1800 },
    "maxCost": { "type": "number", "minimum": 0 },
    "enabled": { "type": "boolean" }
  }
}
