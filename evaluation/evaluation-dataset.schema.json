{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/evaluation-dataset.schema.json",
  "title": "Evaluation Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "version", "samples", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/evaluation-dataset/v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 160 },
    "version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "samples": {
      "type": "array", "minItems": 1, "maxItems": 10000,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["id", "input"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "input": { "type": "string", "minLength": 1, "maxLength": 65536 },
          "expectedSources": { "type": "array", "maxItems": 256, "items": { "type": "string", "maxLength": 512 } },
          "expectedFacts": { "type": "array", "maxItems": 256, "items": { "type": "string", "maxLength": 4096 } },
          "forbiddenActions": { "type": "array", "maxItems": 128, "items": { "type": "string", "maxLength": 256 } }
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
