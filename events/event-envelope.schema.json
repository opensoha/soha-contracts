{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/events/event-envelope.schema.json",
  "title": "Soha Event Envelope",
  "description": "Shared event envelope for audit, operational, integration, and future MCP invocation events.",
  "type": "object",
  "required": ["id", "source", "category", "severity", "summary"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "tenantId": {
      "type": "string",
      "default": "default"
    },
    "workspaceId": {
      "type": "string",
      "default": "default"
    },
    "source": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "eventType": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["debug", "info", "notice", "warning", "error", "critical"]
    },
    "clusterId": { "type": "string" },
    "namespace": { "type": "string" },
    "subject": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "scope": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "summary": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

