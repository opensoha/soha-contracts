{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/agent/multi-agent-plan.schema.json",
  "title": "Bounded Multi-Agent Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "coordinatorRef", "subtasks", "sharedBudget", "status", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/multi-agent-plan/v1" },
    "id": { "type": "string", "minLength": 1 },
    "coordinatorRef": { "type": "string", "minLength": 1 },
    "subtasks": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "object", "required": ["id", "agentProfileRef", "input", "permissionKeys", "status"], "properties": { "id": { "type": "string" }, "agentProfileRef": { "type": "string" }, "input": { "type": "string", "maxLength": 16000 }, "permissionKeys": { "type": "array", "maxItems": 64, "items": { "type": "string" } }, "status": { "enum": ["pending", "running", "completed", "failed", "cancelled"] } }, "additionalProperties": false } },
    "sharedBudget": { "type": "object", "required": ["maxSteps", "maxTokens", "maxCost", "deadlineSeconds"], "properties": { "maxSteps": { "type": "integer", "minimum": 1, "maximum": 100 }, "maxTokens": { "type": "integer", "minimum": 1, "maximum": 2000000 }, "maxCost": { "type": "number", "minimum": 0 }, "deadlineSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 } }, "additionalProperties": false },
    "status": { "enum": ["running", "completed", "failed", "cancelled"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" }
  }
}
