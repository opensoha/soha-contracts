{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/agent-observation.schema.json",
  "title": "Agent Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "runId", "stepId", "kind", "status", "summary", "redacted", "observedAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/agent-observation/v1" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "runId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "stepId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "kind": { "enum": ["model", "tool", "environment", "approval", "provider"] },
    "status": { "enum": ["pending", "running", "succeeded", "failed", "denied", "cancelled"] },
    "summary": { "type": "string", "maxLength": 8192 },
    "artifactRefs": { "type": "array", "maxItems": 128, "items": { "type": "string", "maxLength": 512 } },
    "redacted": { "type": "boolean" },
    "observedAt": { "type": "string", "format": "date-time" }
  }
}
