{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/agent-checkpoint.schema.json",
  "title": "Agent Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "runId", "stepId", "attempt", "sequence", "stateHash", "contextRef", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/agent-checkpoint/v1" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "runId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "stepId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "attempt": { "type": "integer", "minimum": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "stateHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "contextRef": { "type": "string", "minLength": 1, "maxLength": 512 },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
