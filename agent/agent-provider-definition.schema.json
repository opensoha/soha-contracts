{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensoha.dev/schemas/agent-provider-definition.schema.json",
  "title": "Agent Provider Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "kind", "providerVersion", "adapterProtocol", "runtime", "capabilities"],
  "properties": {
    "schemaVersion": { "const": "opensoha.dev/agent-provider-definition/v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
    "displayName": { "type": "string", "maxLength": 160 },
    "pluginId": { "type": "string", "maxLength": 128 },
    "pluginVersion": { "type": "string", "maxLength": 64 },
    "providerVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
    "adapterProtocol": { "type": "string", "minLength": 1, "maxLength": 128 },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["cli", "container", "remote"] },
        "command": { "type": "string", "maxLength": 1024 },
        "args": { "type": "array", "maxItems": 64, "items": { "type": "string", "maxLength": 2048 } },
        "promptArg": { "type": "string", "maxLength": 128 },
        "skillArg": { "type": "string", "maxLength": 128 },
        "providerSkillArg": { "type": "string", "maxLength": 128 },
        "image": { "type": "string", "maxLength": 1024 },
        "endpoint": { "type": "string", "format": "uri", "maxLength": 2048 },
        "healthPath": { "type": "string", "maxLength": 512 }
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "cli" } } }, "then": { "required": ["command"] } },
        { "if": { "properties": { "kind": { "const": "container" } } }, "then": { "required": ["image"] } },
        { "if": { "properties": { "kind": { "const": "remote" } } }, "then": { "required": ["endpoint"] } }
      ]
    },
    "capabilities": { "type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "requiredGatewayCapabilities": { "type": "array", "maxItems": 128, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "requiredScopes": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "secretRefs": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^secret:[^\\s]{1,240}$" } },
    "draining": { "type": "boolean", "default": false }
  }
}
