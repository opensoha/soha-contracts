{
  "schemaVersion": "opensoha.dev/mcp-preset/v1",
  "id": "k8s-readonly",
  "name": "Kubernetes Readonly Diagnosis",
  "version": "0.1.0",
  "description": "Read-only AI Gateway tools for scoped Kubernetes workload diagnosis.",
  "riskLevel": "read",
  "skillRefs": ["k8s-sre"],
  "platformCapabilityRefs": ["cluster.inventory", "workload.read", "pod.logs"],
  "requiredScopes": ["cluster", "namespace"],
  "tools": [
    {
      "name": "k8s.pods.logs",
      "description": "Read recent pod logs in a scoped namespace.",
      "riskLevel": "read",
      "requiredScopes": ["cluster", "namespace"]
    }
  ],
  "guardrails": ["read_only", "no_kubeconfig", "no_secret_output", "scoped_cluster_namespace"]
}
