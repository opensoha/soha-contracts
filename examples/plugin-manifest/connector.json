{
  "id": "opensoha.feishu",
  "name": "Feishu Connector",
  "version": "0.1.0",
  "publisher": "opensoha",
  "type": "connector",
  "description": "Feishu connector capability bundle.",
  "homepage": "https://opensoha.dev/connectors/feishu",
  "compatibility": {
    "soha": ">=0.1.0",
    "contracts": ">=0.1.0 <1.0.0"
  },
  "assets": {
    "connectors": ["connectors/feishu/connector.manifest.json"]
  },
  "capabilities": {
    "tools": ["feishu.message.send_text"]
  },
  "permissions": {
    "required": ["ai.gateway.view", "ai.gateway.invoke"],
    "domain": ["connector"]
  },
  "secrets": {
    "required": [
      {
        "name": "FEISHU_APP_SECRET",
        "description": "Feishu app secret used by the connector runtime.",
        "required": true,
        "secretRef": "connectors/feishu/app-secret"
      }
    ]
  }
}
