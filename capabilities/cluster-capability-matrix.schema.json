{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opensoha.dev/capabilities/cluster-capability-matrix.schema.json",
  "title": "OpenSoha Cluster Capability Matrix",
  "description": "Shared capability matrix for Direct and Agent runtime support across Kubernetes, Helm, YAML, logs, exec, port-forward, and Docker capabilities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "capabilitySetVersion": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/CapabilityMatrixEntry" }
    }
  },
  "$defs": {
    "CapabilityStatus": {
      "type": "string",
      "enum": ["available", "partial", "unsupported"]
    },
    "RiskLevel": {
      "type": "string",
      "enum": ["read", "analyze", "mutate", "execute", "high"]
    },
    "ModeSupport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "enum": ["partial", "unsupported"] }
            }
          },
          "then": { "required": ["reason"] }
        }
      ],
      "properties": {
        "status": { "$ref": "#/$defs/CapabilityStatus" },
        "reason": { "type": "string", "minLength": 1 },
        "diagnostic": { "type": "string" },
        "requiredAgentVersion": { "type": "string" },
        "requiredScopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "CapabilityMatrixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "category", "riskLevel", "requiresApproval", "direct", "agent"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$",
          "description": "Stable capability key such as kubernetes.yaml.apply or docker.logs.stream."
        },
        "label": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["kubernetes", "helm", "yaml", "logs", "exec", "port-forward", "docker", "runtime"]
        },
        "riskLevel": { "$ref": "#/$defs/RiskLevel" },
        "requiresApproval": { "type": "boolean" },
        "direct": { "$ref": "#/$defs/ModeSupport" },
        "agent": { "$ref": "#/$defs/ModeSupport" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
